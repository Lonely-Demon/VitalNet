SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional — Gemini fallback tiers 3/4. App starts and runs fine without it
# (briefings just have fewer fallback tiers if Groq is unavailable).
GEMINI_API_KEY=

# Optional — added to the CORS allow-list in addition to the localhost dev
# origins. Set this to your deployed frontend URL in production.
FRONTEND_URL=

# Optional — comma-separated extra CORS origins (e.g. a staging domain),
# combined with FRONTEND_URL and the dev-only localhost origins.
CORS_ALLOWED_ORIGINS=

# development | staging | production. Gates dev-only CORS origins, HSTS, and
# whether .env.local is loaded at all (never loaded in production).
ENVIRONMENT=development

# Swagger/ReDoc/OpenAPI JSON expose the full API schema — leave off in production.
API_DOCS_ENABLED=false

# Required on every state-changing (POST/PUT/PATCH/DELETE) request alongside
# X-Device-Id. Not a secret — the protection is the CORS preflight a custom
# header forces, not the token's secrecy. Must match the frontend's value.
CSRF_TOKEN=vitalnet-spa

# Optional — shared rate-limit store for horizontally-scaled deployments
# (e.g. redis://host:6379). Empty = in-memory, per-process (fine for a single instance).
RATE_LIMIT_STORAGE_URI=
