VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_API_BASE_URL=https://your-backend.up.railway.app

# Web Push (FEATURES_ROADMAP §1.4) — the VAPID public key, generated alongside
# the backend's vapid_public_key/vapid_private_key (see backend/.env.example).
# Optional: if unset, push notifications are silently disabled client-side.
VITE_VAPID_PUBLIC_KEY=
